# ====================
# DEPENDENCIES
# ====================
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ====================
# BUILD OUTPUTS
# ====================
dist/
dist-ssr/
build/
**/dist/
**/build/
*.tsbuildinfo

# ====================
# ENVIRONMENT FILES (CRITICAL - NEVER COMMIT)
# ====================
.env
.env.*
!.env.example
!.env.test.example
*.local
**/.env
**/.env.*
**/!.env.example

# ====================
# PAYLOAD CMS CONFIG (CRITICAL - NEVER COMMIT)
# ====================
**/payload.config.ts
**/payload.config.js
**/payload.config.json
!**/payload.config.example.ts
!**/payload.config.example.js

# ====================
# SECRETS & KEYS (CRITICAL - NEVER COMMIT)
# ====================
*.pem
*.key
*.cert
*.crt
*.p12
secrets/
**/secrets/
.ssl/
**/.ssl/

# ====================
# DATABASE FILES
# ====================
data/
**/data/*.json
*.db
*.sqlite
*.sqlite3
*.db.json

# ====================
# IDE & EDITOR FILES
# ====================
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db
desktop.ini
**/.vscode/settings.json
**/.vscode/launch.json

# ====================
# OPERATING SYSTEM FILES
# ====================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ====================
# TEMPORARY FILES
# ====================
*.tmp
*.temp
*.cache
**/.cache
*.log
logs/
**/logs/
*.pid
*.seed
*.pid.lock

# ====================
# PACKAGE MANAGER LOCKS (Optional - Remove if you want to commit them)
# ====================
package-lock.json
yarn.lock
pnpm-lock.yaml

# ====================
# TESTING COVERAGE
# ====================
coverage/
.nyc_output/
**/coverage/
*.lcov

# ====================
# DEBUG FILES
# ====================
debug.log
**/debug.log
*.log

# ====================
# MISC
# ====================
*.tgz
*.gz
*.rar
*.7z
.DS_Store
.vercel
.next/
.nuxt/
.output/
.terraform/
*.tfstate
*.tfstate.*

# ====================
# MEDIA UPLOADS (If you have uploaded files locally)
# ====================
media/
uploads/
**/media/
**/uploads/

# ====================
# BACKUP FILES
# ====================
*.bak
*.backup
*.old
*.orig